{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "@esnet/esnet-tokens#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["@esnet/esnet-tokens#build", "^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test:playwright": {
      "cache": false
    },
    "test:updatesnaps": {
      "cache": false
    }
  }
}
