{
  "name": "@esnet/esnet-tokens",
  "version": "1.1.1",
  "type": "module",
  "description": "A set of reusable UI tokens for the various ESnet frontend systems.",
  "author": "Jason Roeckle",
  "scripts": {
    "build": "node ./build.js && pnpm run format && rollup --config rollup.config.js",
    "dev": "rollup -c -w",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,jsx}\""
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/esnet-tokens.esm.js",
      "require": "./dist/esnet-tokens.cjs.js",
      "default": "./dist/tokens.js"
    },
    "./*": "./dist/*"
  },
  "license": "MIT",
  "publishConfig": {
    "@esnet:registry": "https://gitlab.es.net/api/v4/projects/898/packages/npm/"
  },
  "dependencies": {
    "sd-tailwindcss-transformer": "^1.4.6"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.3",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "rollup": "^4.27.3",
    "style-dictionary": "^3.9.2"
  }
}
