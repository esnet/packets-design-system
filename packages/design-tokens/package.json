{
  "name": "@esnet/esnet-tokens",
  "version": "0.2.2",
  "type": "module",
  "main": "dist/esnet-tokens.cjs.js",
  "module": "dist/esnet-tokens.esm.js",
  "browser": "dist/esnet-tokens.umd.js",
  "description": "A set of reusable UI tokens for the various ESnet frontend systems.",
  "author": "Jason Roeckle",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./build.js",
    "postbuild": "pnpm run format; rollup --config",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,jsx}\""
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "rollup": "^4.12.0",
    "style-dictionary": "^3.7.2"
  },
  "dependencies": {
    "sd-tailwindcss-transformer": "^1.3.1"
  },
  "publishConfig": {
    "@esnet:registry": "https://gitlab.es.net/api/v4/projects/665/packages/npm/"
  }
}
