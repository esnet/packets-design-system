        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "rootDir": "src",
        "types": ["node"],
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["src"]
}
