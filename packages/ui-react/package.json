{
  "name": "@esnet/packets-ui-react",
  "version": "0.9.0",
  "description": "The Packets Design System React Package",
  "author": "Jason Roeckle",
  "scripts": {
    "rimraf": "./node_modules/rimraf/bin.js",
    "build": "rimraf dist && rollup -c",
    "dev": "rollup -c -w",
    "test": "playwright clear-cache && playwright test",
    "test:ui": "playwright clear-cache && playwright test --ui",
    "test:updatesnaps": "playwright clear-cache && playwright test --update-snapshots",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@esnet/packets-ui-css": "workspace:^"
  },
  "peerDependencies": {
    "antd": "^5.4.0",
    "lucide-react": "^0.525.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "^7.26.0",
    "@esnet/esnet-tokens": "workspace:^",
    "@playwright/experimental-ct-react": "^1.57.0",
    "@playwright/test": "^1.57.0",
    "@repo/eslint-config": "workspace:^",
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "gh-pages": "^5.0.0",
    "identity-obj-proxy": "^3.0.0",
    "playwright": "^1.57.0",
    "postcss-import": "^16.1.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^4.4.1",
    "rollup": "^3.29.5",
    "rollup-plugin-dts": "^5.3.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esnet/packets-design-system"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui",
    "esnet",
    "packets",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/bundle.js",
  "module": "dist/esm/bundle.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/cjs/bundle.js",
      "import": "./dist/esm/bundle.js"
    },
    "./style.css": {
      "import": "./dist/esm/style.css",
      "require": "./dist/cjs/style.css"
    },
    "./src/*": "./src/*"
  }
}
