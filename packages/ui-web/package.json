{
  "name": "@esnet/packets-ui-web",
  "version": "0.1.0",
  "type": "module",
  "description": "The Packets Design System Web Components Package",
  "author": "Johanna Lee",
  "scripts": {
    "rimraf": "./node_modules/rimraf/bin.js",
    "build": "rimraf dist && rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:updatesnaps": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@esnet/packets-ui-css": "workspace:^"
  },
  "peerDependencies": {
    "antd": "^5.4.0",
    "lucide": "^0.525.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@esnet/esnet-tokens": "workspace:^",
    "@playwright/test": "^1.57.0",
    "@repo/eslint-config": "workspace:^",
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-jest": "^29.7.0",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "gh-pages": "^5.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lucide": "^0.525.0",
    "postcss-import": "^16.1.0",
    "prop-types": "^15.8.1",
    "rimraf": "^4.4.1",
    "rollup": "^3.29.5",
    "rollup-plugin-dts": "^5.3.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esnet/packets-design-system"
  },
  "keywords": [
    "design-system",
    "web-components",
    "components",
    "ui",
    "esnet",
    "packets",
    "typescript",
    "framework-agnostic"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/bundle.js",
  "module": "dist/esm/bundle.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/cjs/bundle.js",
      "import": "./dist/esm/bundle.js"
    },
    "./style.css": {
      "import": "./dist/esm/style.css",
      "require": "./dist/cjs/style.css"
    }
  }
}
