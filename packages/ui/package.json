{
  "name": "@esnet/packets-ui",
  "version": "0.0.2",
  "type": "module",
  "description": "The Packets Design System UI Package",
  "author": "Jason Roeckle",
  "scripts": {
    "lint": "eslint *.ts*",
    "build": "rollup -c",
    "dev": "pnpm build --watch",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:updatesnaps": "jest --updateSnapshot"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    }
  },
  "devDependencies": {
    "@esnet/esnet-tokens": "workspace:^",
    "@repo/eslint-config": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "add": "^2.0.6",
    "eslint": "^8.57.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss-import": "^16.1.0",
    "react": "^18.2.0",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-postcss-modules": "^2.1.1",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "@esnet:registry": "https://gitlab.es.net/api/v4/projects/898/packages/npm/"
  },
  "files": [
    "dist",
    "dist/*.css"
  ],
  "types": "dist/index.d.ts"
}
