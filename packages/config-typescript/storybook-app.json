{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "declarationMap": false,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext", "ES2015"],
    "module": "ESNext",
    "noEmit": true,
    "resolveJsonModule": true,
    "target": "es6"
  }
}
